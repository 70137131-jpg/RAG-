# === Required API Keys ===
GOOGLE_API_KEY=your-google-api-key-here
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=squad-rag-integrated

# === Upstash Redis ===
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# === PostgreSQL ===
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === Admin Auth ===
# ADMIN_API_TOKEN is preferred; API_AUTH_TOKEN is a supported fallback.
ADMIN_API_TOKEN=change-this-to-a-strong-random-token

# === LLM Provider (choose one) ===
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash

# For OpenRouter instead:
# LLM_PROVIDER=openrouter
# LLM_MODEL=openai/gpt-4o-mini
# OPENROUTER_API_KEY=your-openrouter-key-here

# === Optional ===
CHAT_LOG_RETENTION_DAYS=7
COOKIE_SECURE=false
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
